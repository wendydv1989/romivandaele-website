        },
        {
            "id": "https://romivandaele.com/works/reno-blazer-2025/",
            "url": "https://romivandaele.com/works/reno-blazer-2025/",
            "title": "Reno Blazer (2025)",
            "summary": "Stunning black wool blazer, a one off signature piece. Designed for elegance&hellip;",
            "content_html": "<div class=\"gallery-wrapper\"><div class=\"gallery\"  data-is-empty=\"false\" data-translation=\"Add images\" data-columns=\"3\">\n<figure class=\"gallery__item\"><a href=\"https://romivandaele.com/media/posts/28/gallery/IMG_5476.jpeg\" data-size=\"3024x4032\"><img loading=\"lazy\" src=\"https://romivandaele.com/media/posts/28/gallery/IMG_5476-thumbnail.jpeg\" alt=\"\" width=\"768\" height=\"1024\"></a></figure>\n<figure class=\"gallery__item\"><a href=\"https://romivandaele.com/media/posts/28/gallery/IMG_5478.jpeg\" data-size=\"3024x4032\"><img loading=\"lazy\" src=\"https://romivandaele.com/media/posts/28/gallery/IMG_5478-thumbnail.jpeg\" alt=\"\" width=\"768\" height=\"1024\"></a></figure>\n</div></div>\n<p data-start=\"103\" data-end=\"360\">Stunning black wool blazer, a one off signature piece. Designed for elegance and versatility, the blazer features intricate gold embroidery in a floral pattern, adding a touch of opulence to its sleek silhouette.</p>\n<p data-start=\"362\" data-end=\"602\">Perfect for formal occasions or statement styling, this piece effortlessly pairs with fitted tops and heels, offering a refined yet bold aesthetic. It's part of our Reno duet, a blazer and a <a href=\"https://romivandaele.com/works/reno-skirt/\">skirt</a>. </p>\n<p data-start=\"362\" data-end=\"602\"> </p>\n<p data-start=\"362\" data-end=\"602\"> </p>",
