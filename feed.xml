            <![CDATA[
                    <p><img src="https://romivandaele.com/media/posts/32/IMG_2641.jpeg" class="type:primaryImage" alt="" /></p>
                <div>
<div class="gallery-wrapper"><div class="gallery"  data-is-empty="false" data-translation="Add images" data-columns="3">
<figure class="gallery__item"><a href="https://romivandaele.com/media/posts/32/gallery/IMG_2642-2.jpeg" data-size="3024x4032"><img loading="lazy" src="https://romivandaele.com/media/posts/32/gallery/IMG_2642-2-thumbnail.jpeg" alt="" width="768" height="1024"></a></figure>
<figure class="gallery__item"><a href="https://romivandaele.com/media/posts/32/gallery/IMG_2646-2.jpeg" data-size="3024x4032"><img loading="lazy" src="https://romivandaele.com/media/posts/32/gallery/IMG_2646-2-thumbnail.jpeg" alt="" width="768" height="1024"></a></figure>
